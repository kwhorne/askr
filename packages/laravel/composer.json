{
    "name": "kwhorne/askr-laravel",
    "description": "Laravel integration for the Askr application server: shared-memory session, cache, locks and queue drivers — Redis-free on a single box.",
    "keywords": ["laravel", "askr", "session", "cache", "queue", "shared-memory"],
    "homepage": "https://github.com/kwhorne/askr",
    "license": "MIT",
    "authors": [
        { "name": "Knut W. Horne", "email": "kh@gets.no" }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0",
        "illuminate/contracts": "^11.0 || ^12.0 || ^13.0"
    },
    "autoload": {
        "psr-4": {
            "Askr\\Laravel\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Askr\\Laravel\\AskrServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable"
}
